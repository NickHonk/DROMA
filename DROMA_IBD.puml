@startuml DROMA_IBD
' =====================================================================
'  DROMA — SysML Internal Block Diagram (Signalfluss)
'  Quelle: Verschaltung der fünf Modellreferenzen in quadcop.slx
'  blau gestrichelt = Datenbus, rot durchgezogen = physikalisch
' =====================================================================
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam componentStyle rectangle
skinparam defaultFontName "Segoe UI"
skinparam component {
  BackgroundColor<<Deployed Software>> #D4E6F1
  BorderColor<<Deployed Software>>     #2E86C1
  BackgroundColor<<SITL Environment>>  #D5F5E3
  BorderColor<<SITL Environment>>      #27AE60
  BackgroundColor<<HW>>                #FADBD8
  BorderColor<<HW>>                    #C0392B
  FontColor black
}

title <b>DROMA — Signalfluss in quadcop.slx</b>\n<size:10>Der Lageregelkreis läuft mit 1 kHz auf der Drohne, die Positionsregelung mit 100 Hz auf der Bodenstation</size>

package "Drohne" as ZDRONE {
  component "**Flugregler**\n<size:9>mcu.slx, wird zu C++</size>\n<size:8>Lageschätzer, Lageregler, Notabstieg,</size>\n<size:8>Kill-Latch, Batterieüberwachung</size>" as MCU <<Deployed Software>>
  component "Akku\n<size:9>Pin 41, rohe 12-Bit-Counts</size>" as BATT <<HW>>
  component "Taster\n<size:9>Pin 21, schaltet gegen Masse</size>" as BTN <<HW>>
}

package "Simulation auf dem Host-PC" as ZSITL {
  component "**Flugdynamik**\n<size:9>plant.slx, Starrkörper und Propeller</size>" as PLANT <<SITL Environment>>
  component "**Sensorik**\n<size:9>sensors.slx, IMU und Mocap</size>\n<size:8>hier wird der Gyro-Bias abgezogen</size>" as SENS <<SITL Environment>>
  component "**Funkstrecke**\n<size:9>link.slx, Sender, Kanal, Empfänger</size>" as LINK <<SITL Environment>>
}

package "Bodenstation" as ZGS {
  component "**Bodenstation**\n<size:9>gcu.slx</size>\n<size:8>Bahnplanung, Positionsregler, Supervisor</size>" as GCU <<Deployed Software>>
}

' ================= physikalisch (rot, durchgezogen) ==================
MCU   -[#C0392B,bold]->  PLANT : rotor_cmd\n<size:9>Motorbefehl, erzeugt Schub</size>
PLANT -[#C0392B,bold]->  SENS  : Bewegung\n<size:9>Lage, Beschleunigung, Drehrate</size>
BTN   -[#C0392B,bold]->  MCU   : btn_ack\n<size:9>Tastendruck zum Entriegeln</size>

' ================= Datenbusse (blau, gestrichelt) ====================
SENS  -[#1F77B4,dashed]->  MCU  : Bus_IMU
LINK  -[#1F77B4,dashed]->  MCU  : Bus_Cmd\n<size:9>Sollwerte für Schub und Lage, dazu estop und ack</size>
GCU   -[#1F77B4,dashed]->  LINK : Bus_Cmd
SENS  -[#1F77B4,dashed]->  GCU  : Bus_Mocap
PLANT -[#1F77B4,dashed]->  GCU  : Bus_State\n<size:9>Telemetrie, langsamer getaktet</size>
BATT  -[#1F77B4,dashed]->  MCU  : batt_count

' ================= Anmerkungen =======================================
note bottom of MCU
  Zwei weitere Ausgänge gehen auf der echten Drohne an die
  Hardware, in der Simulation werden sie nur mitgeschrieben:
  throttle steuert die vier ESCs, led zeigt den Ladezustand
  in drei Stufen an.

  Der Kill-Latch rastet ein, wenn die Drehrate zu hoch wird,
  estop auf 2 geht, die Drohne länger als 80 ms mehr als
  80 Grad kippt, oder jemand den Taster drückt. Gelöst wird er
  nur durch eine steigende Flanke auf ack.
end note

note as N_BENCH
  <b>Das zweite Modell, bench.slx</b>
  Dort fehlen Flugdynamik, Sensorik und Funkstrecke.
  Die Lage kommt stattdessen live von OptiTrack, und die
  Kommandos gehen über die serielle Schnittstelle an den
  Sende-Teensy, der sie per Funk zur echten Drohne bringt.
  Simuliert wird nur noch die Bodenstation.
end note
N_BENCH .. ZGS

legend right
  |= Linie |= Bedeutung |
  |<#1F77B4>  - -   | Datenbus zwischen zwei Rechnern |
  |<#C0392B>  ===   | physikalisch: Kraft, Messung, Tastendruck |
  |<#D4E6F1>        | Code, der später auf einem Rechner läuft |
  |<#D5F5E3>        | nur simuliert, auf dem Host-PC |
  |<#FADBD8>        | echte Hardware |
endlegend
@enduml
